# Normalize line endings so the repo works on every platform.
# Bash scripts MUST keep LF: a Windows clone with core.autocrlf=true would
# otherwise rewrite them to CRLF and break them under WSL / Git Bash / Linux.
* text=auto

setup.sh text eol=lf
bin/ai-* text eol=lf
bin/book-to-skill text eol=lf
*.sh text eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
