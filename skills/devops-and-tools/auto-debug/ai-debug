#!/usr/bin/env bash
# wz-ai-debug — Spec-kit for automated debug, linting, and auto-correction
# Source: Wizard-AI skill (auto-debug)
# Usage: wz-ai-debug check [--fix] [--fast] | wz-ai-debug log | wz-ai-debug analyze <file>
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
RESET='\033[0m'

AUTO_FIX=false
FAST=false

usage() {
  echo -e "${BOLD}Usage:${RESET} wz-ai-debug <command> [options]"
  echo ""
  echo -e "${BOLD}Commands:${RESET}"
  echo "  check              Run full spec-kit (lint + format + type + tests)"
  echo "  check --fix        Same + auto-correct fixable issues"
  echo "  check --fast       Lint only (fastest)"
  echo "  log                Show last 20 SQLite debug log entries"
  echo "  log --errors       Show only ERROR level entries"
  echo "  analyze <file>     Compress and summarize a log/traceback file"
  echo "  clean              Clear the SQLite debug log"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  wz-ai-debug check"
  echo "  wz-ai-debug check --fix"
  echo "  wz-ai-debug log --errors"
  echo "  wz-ai-debug analyze /tmp/error.log"
  exit 0
}

gate_status() {
  local name="$1"
  local ok="$2"
  if [ "$ok" = "true" ]; then
    echo -e "  ${GREEN}✅ $name${RESET}"
  else
    echo -e "  ${RED}❌ $name${RESET}"
  fi
}

cmd="${1:-}"
shift || true

case "$cmd" in

  check)
    for arg in "$@"; do
      case "$arg" in
        --fix) AUTO_FIX=true ;;
        --fast) FAST=true ;;
      esac
    done

    echo -e "${BOLD}${CYAN}🔍 wz-ai-debug Spec-Kit${RESET}"
    echo ""

    PASS_COUNT=0
    FAIL_COUNT=0

    # ── Gate 1: Ruff lint ──────────────────────────────────────────────────
    echo -e "${BOLD}Gate 1 — Lint (ruff)${RESET}"
    # Detect ruff: global, venv, or python -m
    RUFF_CMD=""
    if command -v ruff &>/dev/null; then
      RUFF_CMD="ruff"
    elif [ -x ".venv/bin/ruff" ]; then
      RUFF_CMD=".venv/bin/ruff"
    elif python -m ruff --version &>/dev/null 2>&1; then
      RUFF_CMD="python -m ruff"
    fi

    if [ -n "$RUFF_CMD" ]; then
      if $AUTO_FIX; then
        $RUFF_CMD check . --fix 2>&1 | tail -5
      fi
      if $RUFF_CMD check . 2>&1; then
        gate_status "Lint" "true"; PASS_COUNT=$((PASS_COUNT+1))
      else
        gate_status "Lint" "false"; FAIL_COUNT=$((FAIL_COUNT+1))
        if ! $AUTO_FIX; then
          echo -e "   ${BLUE}Run: wz-ai-debug check --fix  to auto-correct${RESET}"
        fi
      fi
    else
      echo -e "  ${YELLOW}⚠️  ruff not found — install: uv add ruff${RESET}"
    fi
    echo ""

    if $FAST; then
      echo -e "${YELLOW}[--fast mode] Skipping format, type, and test gates.${RESET}"
    else

      # ── Gate 2: Ruff format ──────────────────────────────────────────────
      echo -e "${BOLD}Gate 2 — Format (ruff format)${RESET}"
      if [ -n "${RUFF_CMD:-}" ]; then
        if $AUTO_FIX; then
          $RUFF_CMD format . 2>&1 | tail -3
        fi
        if $RUFF_CMD format --check . 2>&1; then
          gate_status "Format" "true"; PASS_COUNT=$((PASS_COUNT+1))
        else
          gate_status "Format" "false"; FAIL_COUNT=$((FAIL_COUNT+1))
          if ! $AUTO_FIX; then
            echo -e "   ${BLUE}Run: $RUFF_CMD format .${RESET}"
          fi
        fi
      else
        echo -e "  ${YELLOW}⚠️  ruff not found — skipping format gate${RESET}"
      fi
      echo ""

      # ── Gate 3: Tests ────────────────────────────────────────────────────
      echo -e "${BOLD}Gate 3 — Tests (pytest)${RESET}"
      if command -v pytest &>/dev/null || python -m pytest --version &>/dev/null 2>&1; then
        TEST_DIR=$(find . -name "test_*.py" -o -name "*_test.py" 2>/dev/null | head -1)
        if [ -n "$TEST_DIR" ]; then
          if python -m pytest -x -q 2>&1; then
            gate_status "Tests" "true"; PASS_COUNT=$((PASS_COUNT+1))
          else
            gate_status "Tests" "false"; FAIL_COUNT=$((FAIL_COUNT+1))
          fi
        else
          echo -e "  ${YELLOW}⚠️  No test files found — skipping${RESET}"
        fi
      else
        echo -e "  ${YELLOW}⚠️  pytest not installed — skipping${RESET}"
      fi
      echo ""

      # ── Gate 4: Security scan (lightweight) ─────────────────────────────
      echo -e "${BOLD}Gate 4 — Secret Scan${RESET}"
      SECRETS=$(grep -rn "password\s*=\s*['\"][^'\"]\|secret\s*=\s*['\"][^'\"]\|api_key\s*=\s*['\"][^'\"" \
        --include="*.py" . 2>/dev/null | grep -v "test\|#\|\.git" | head -5 || true)
      if [ -z "$SECRETS" ]; then
        gate_status "Secret scan" "true"; PASS_COUNT=$((PASS_COUNT+1))
      else
        gate_status "Secret scan" "false"; FAIL_COUNT=$((FAIL_COUNT+1))
        echo "$SECRETS" | head -3
      fi
      echo ""

    fi

    # ── Summary ────────────────────────────────────────────────────────────
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    TOTAL=$((PASS_COUNT + FAIL_COUNT))
    if [ "$FAIL_COUNT" -eq 0 ]; then
      echo -e "${GREEN}${BOLD}✅ All $TOTAL gates passed — ready to commit/merge${RESET}"
    else
      echo -e "${RED}${BOLD}❌ $FAIL_COUNT/$TOTAL gates failed${RESET}"
      echo -e "   ${BLUE}Run: wz-ai-debug check --fix  to auto-correct${RESET}"
      exit 1
    fi
    ;;

  log)
    DB_FILE=""
    for f in "app_debug.sqlite" "debug.sqlite" "app.sqlite"; do
      if [ -f "$f" ]; then DB_FILE="$f"; break; fi
    done

    ERRORS_ONLY=false
    for arg in "$@"; do
      [ "$arg" = "--errors" ] && ERRORS_ONLY=true
    done

    if [ -z "$DB_FILE" ]; then
      echo -e "${YELLOW}⚠️  No SQLite debug database found (looked for app_debug.sqlite)${RESET}"
      exit 0
    fi

    echo -e "${BOLD}${CYAN}📋 Debug Log — $DB_FILE${RESET}"
    echo ""

    if $ERRORS_ONLY; then
      python3 -c "
import sqlite3
con = sqlite3.connect('$DB_FILE')
try:
    rows = con.execute(\"SELECT timestamp, level, message, traceback FROM logs WHERE level='ERROR' ORDER BY timestamp DESC LIMIT 20\").fetchall()
    if not rows:
        print('No ERROR entries found.')
    for r in rows:
        print(f'[{r[0]}] {r[1]}: {r[2]}')
        if r[3]: print(f'  TRACE: {r[3][:300]}')
        print()
except Exception as e:
    print(f'Could not read logs table: {e}')
"
    else
      python3 -c "
import sqlite3
con = sqlite3.connect('$DB_FILE')
try:
    rows = con.execute('SELECT timestamp, level, message FROM logs ORDER BY timestamp DESC LIMIT 20').fetchall()
    if not rows:
        print('Log is empty.')
    for r in rows:
        print(f'[{r[0]}] {r[1]}: {r[2]}')
except Exception as e:
    print(f'Could not read logs table: {e}')
"
    fi
    ;;

  analyze)
    FILE="${1:-}"
    if [ -z "$FILE" ]; then
      echo -e "${RED}❌ Provide a file to analyze: wz-ai-debug analyze <file>${RESET}"
      exit 1
    fi
    if [ ! -f "$FILE" ]; then
      echo -e "${RED}❌ File not found: $FILE${RESET}"
      exit 1
    fi
    echo -e "${CYAN}🔬 Analyzing: $FILE${RESET}"
    if command -v sqz &>/dev/null; then
      cat "$FILE" | sqz
    elif command -v wz-ai-squeeze &>/dev/null; then
      cat "$FILE" | wz-ai-squeeze
    else
      echo -e "${YELLOW}⚠️  sqz not installed. Raw output:${RESET}"
      tail -50 "$FILE"
    fi
    ;;

  clean)
    DB_FILE=""
    for f in "app_debug.sqlite" "debug.sqlite"; do
      if [ -f "$f" ]; then DB_FILE="$f"; break; fi
    done
    if [ -z "$DB_FILE" ]; then
      echo -e "${YELLOW}No SQLite debug database found.${RESET}"
      exit 0
    fi
    read -r -p "$(echo -e "${BOLD}Clear all logs from $DB_FILE? [y/N]:${RESET} ")" CONFIRM
    if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
      python3 -c "import sqlite3; con=sqlite3.connect('$DB_FILE'); con.execute('DELETE FROM logs'); con.commit(); print('✅ Log cleared')"
    fi
    ;;

  --help|-h)
    usage
    ;;

  *)
    echo -e "${RED}❌ Unknown command: $cmd${RESET}"
    usage
    ;;
esac
