#!/usr/bin/env python3

# Telemetry hook
import os
import subprocess
try:
    DIR = os.path.dirname(os.path.abspath(__file__))
    WIZARD_AI_DIR = os.path.dirname(DIR)
    subprocess.Popen(["python3", os.path.join(WIZARD_AI_DIR, "hub/api/log_event.py"), "ai-quota", "execute", "100", "0.15"])
except Exception:
    pass

"""ai-quota — Wrapper CLI per Cockpit Tools (Quote e Provider AI)
Legge lo stato delle quote, provider attivi e abbonamenti.
Se Cockpit Tools non è configurato, restituisce uno stato chiaro per la dashboard.
"""
import json
import os
import sys
import argparse


def get_cockpit_db_path():
    home = os.path.expanduser("~")
    if sys.platform == "win32":
        return os.path.join(os.environ.get("APPDATA", home), "cockpit-tools", "accounts.json")
    elif sys.platform == "darwin":
        return os.path.join(home, "Library", "Application Support", "cockpit-tools", "accounts.json")
    else:
        return os.path.join(home, ".local", "share", "cockpit-tools", "accounts.json")

def get_cockpit_status():
    """
    Legge lo stato delle quote e dei provider da Cockpit Tools.
    Se il file non esiste, restituisce {"status": "not_configured"}.
    """
    # Se stiamo girando nel container Docker, il path potrebbe essere quello di Linux
    # indipendentemente dal sistema host. Controlliamo anche i percorsi montati dal docker-compose.
    possible_paths = [
        get_cockpit_db_path(),
        "/root/.local/share/cockpit-tools/accounts.json",
        "/root/Library/Application Support/cockpit-tools/accounts.json",
        "/root/AppData/Roaming/cockpit-tools/accounts.json",
        os.path.expanduser("~/.ai-skills/cockpit-tools/accounts.json")
    ]
    
    cockpit_db_path = None
    for p in possible_paths:
        if os.path.exists(p):
            cockpit_db_path = p
            break
            
    if cockpit_db_path:
        try:
            with open(cockpit_db_path, "r") as f:
                data = json.load(f)
                # Check if this is actually Cockpit Tools by looking for 'active_provider' or 'quota' or 'status'
                if "status" not in data and "active_provider" not in data:
                    # Not the right file format, keep searching
                    pass
                else:
                    if "status" not in data:
                        data["status"] = "success"
                    return data
        except json.JSONDecodeError:
            return {
                "status": "error",
                "message": f"Il file {cockpit_db_path} è corrotto. Avvia Cockpit Tools per rigenerarlo."
            }
        except Exception as e:
            return {
                "status": "error",
                "message": f"Errore nella lettura di Cockpit Tools in {cockpit_db_path}: {str(e)}"
            }
    
    # Cockpit Tools non configurato
    searched_paths = "\n  - ".join(possible_paths)
    return {
        "status": "not_configured",
        "message": f"Cockpit Tools non è ancora configurato. Avvia l'app Cockpit Tools per fare il login e collegare i tuoi account AI.\n\nPercorsi cercati:\n  - {searched_paths}",
        "install_hint": "git clone https://github.com/jlcodes99/cockpit-tools.git ~/.ai-skills/cockpit-tools"
    }


def main():
    parser = argparse.ArgumentParser(description="Wrapper CLI per Cockpit Tools (Quote e Provider AI)")
    parser.add_argument("--json", action="store_true", help="Restituisce l'output in formato JSON")
    args = parser.parse_args()

    status = get_cockpit_status()

    if args.json:
        print(json.dumps(status, indent=2))
        return

    # Human-readable output
    print("========================================")
    print(" 🚀 Cockpit Tools - AI Provider Status ")
    print("========================================")
    
    if status["status"] == "not_configured":
        print("⚠️  Cockpit Tools non configurato.")
        print("")
        print(status["message"])
        print("")
        print("Per iniziare:")
        print(f"  {status['install_hint']}")
        print("========================================")
        return
    
    if status["status"] == "error":
        print(f"❌ Errore: {status['message']}")
        print("========================================")
        return

    # Status: success - mostra i dati reali
    p = status.get("active_provider", {})
    q = status.get("quota", {})
    
    print(f"Provider Attivo: {p.get('name', 'N/A')} ({p.get('type', 'N/A')})")
    print(f"Stato:           {p.get('status', 'N/A').upper()}")
    print("-" * 40)
    
    if q:
        used = q.get("used_tokens", 0)
        total = q.get("total_limit", 0)
        pct = q.get("percentage_used", 0)
        print(f"Abbonamento:     {q.get('subscription', 'N/A')}")
        print(f"Token Usati:     {used:,} / {total:,} ({pct}%)")
        print(f"Reset previsto:  {q.get('reset_date', 'N/A')}")
    
    print("-" * 40)
    
    accounts = status.get("other_accounts", [])
    if accounts:
        print("Altri Account Collegati:")
        for acc in accounts:
            icon = "✅" if acc.get("status") == "active" else "❌"
            plan_info = f"[{acc['plan']}]" if "plan" in acc else ""
            print(f" {icon} {acc.get('name', 'N/A')} {plan_info}")
    
    print("========================================")
    print("Avvia l'app Cockpit Tools per gestire gli account.")


if __name__ == "__main__":
    main()
