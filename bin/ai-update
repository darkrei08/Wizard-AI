#!/usr/bin/env bash
# ai-update — Automates the update process for Wizard-AI and external skills.

set -euo pipefail

QUIET=0
if [[ "${1:-}" == "--quiet" ]]; then
  QUIET=1
fi

log() {
  if [ "$QUIET" -eq 0 ]; then
    echo -e "$1"
  fi
}

# Source env if WIZARD_AI_DIR is not set
if [ -z "${WIZARD_AI_DIR:-}" ] && [ -f "$HOME/.config/wizard-ai/env" ]; then
  source "$HOME/.config/wizard-ai/env"
fi

log "\n🧙‍♂️ Wizard-AI Update Process"
log "================================="

# 1. Update Wizard-AI repository
# 1. Update Wizard-AI repository with safe rollback
WIZARD_DIR="${WIZARD_AI_DIR:-$HOME/.wizard-ai}"
if [ -d "$WIZARD_DIR/.git" ]; then
  log "\n📦 Updating Wizard-AI repository..."
  PREV_WIZARD_COMMIT=$(git -C "$WIZARD_DIR" rev-parse HEAD 2>/dev/null || echo "")
  if ! git -C "$WIZARD_DIR" pull --ff-only ${QUIET:+--quiet} 2>/dev/null; then
    log "  ⚠ git pull failed or conflicted. Maintaining current stable commit."
  else
    # Verify setup.sh and main scripts still parse cleanly
    if [ -f "$WIZARD_DIR/setup.sh" ] && ! bash -n "$WIZARD_DIR/setup.sh" &>/dev/null; then
      log "  ❌ Updated repository has syntax errors! Rolling back to ${PREV_WIZARD_COMMIT}..."
      [ -n "$PREV_WIZARD_COMMIT" ] && git -C "$WIZARD_DIR" reset --hard "$PREV_WIZARD_COMMIT" --quiet 2>/dev/null || true
    else
      log "  ✓ Wizard-AI updated and verified cleanly."
    fi
  fi
fi

# 2. Update all skill repositories in ~/.ai-skills/ with safe rollback
AI_SKILLS="$HOME/.ai-skills"
if [ -d "$AI_SKILLS" ]; then
  log "\n📚 Updating external skill repositories..."
  
  # List of core repositories
  declare -A CORE_REPOS=(
    ["claude-mem"]="https://github.com/thedotmack/claude-mem.git"
    ["headroom"]="https://github.com/chopratejas/headroom.git"
    ["Infographic"]="https://github.com/antvis/Infographic.git"
    ["cybersecurity-skills"]="https://github.com/mukul975/Anthropic-Cybersecurity-Skills.git"
    ["lean-ctx"]="https://github.com/yvgude/lean-ctx.git"
    ["stitch-skills"]="https://github.com/google-labs-code/stitch-skills.git"
    ["design.md"]="https://github.com/google-labs-code/design.md.git"
  )

  for name in "${!CORE_REPOS[@]}"; do
    repo_url="${CORE_REPOS[$name]}"
    repo_dir="$AI_SKILLS/$name"
    
    if [ ! -d "$repo_dir" ]; then
      log "  -> Cloning missing repository $name..."
      if ! git clone --depth 1 "$repo_url" "$repo_dir" ${QUIET:+--quiet} 2>/dev/null; then
        log "     ❌ Clone failed, cleaning up incomplete folder."
        rm -rf "$repo_dir"
      fi
    else
      log "  -> Updating $name..."
      local prev_skill_commit=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null || echo "")
      if ! git -C "$repo_dir" pull --ff-only ${QUIET:+--quiet} 2>/dev/null; then
        [ -n "$prev_skill_commit" ] && git -C "$repo_dir" reset --hard "$prev_skill_commit" --quiet 2>/dev/null || true
        log "     ⚠ Update failed. Rolled back $name to ${prev_skill_commit}."
      fi
    fi
  done
fi

# 3. Update uv tools safely
if command -v npm &>/dev/null; then
  log "\n📦 Upgrading global NPM packages (Wizard-AI CLI, AI-OS, etc)..."
  npm update -g ${QUIET:+--quiet} 2>/dev/null || log "  ⚠ npm update -g encountered warnings or partial errors (retaining working packages)."
fi

if command -v uv >/dev/null 2>&1; then
  log "\n🛠️ Upgrading global CLI tools via uv..."
  if [ "$QUIET" -eq 1 ]; then
    uv tool upgrade --all --quiet >/dev/null 2>&1 || log "  ⚠ uv tool upgrade encountered minor issues, retained working tool versions."
  else
    uv tool upgrade --all || log "  ⚠ uv tool upgrade encountered minor issues, retained working tool versions."
  fi

  # Auto-inject updated CLI skills into the master skills folder
  if command -v graphify >/dev/null 2>&1; then
    log "  -> Auto-injecting graphify skill updates..."
    graphify antigravity install >/dev/null 2>&1 || true
  fi
fi

# 4. Sync skills
if command -v ai-sync-skills >/dev/null 2>&1; then
  log "\n🔄 Syncing agent skills..."
  ai-sync-skills >/dev/null 2>&1 || true
fi

log "\n✅ Update complete!"

# Show cross-platform desktop notification
show_notification() {
  local title="Wizard-AI"
  local msg="Aggiornamento ambiente e skill (wiki incluse) completato con successo!"
  
  if command -v notify-send >/dev/null 2>&1; then
    # Linux (GNOME, KDE, XFCE, etc.)
    notify-send "$title" "$msg" || true
  elif command -v osascript >/dev/null 2>&1; then
    # macOS
    osascript -e "display notification \"$msg\" with title \"$title\"" || true
  fi
}

show_notification
