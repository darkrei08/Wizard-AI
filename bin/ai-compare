#!/usr/bin/env python3
# ai-compare — A/B Test prompts across multiple LLMs using aisuite
import sys
import os
import json
import argparse
from pathlib import Path

# Try importing aisuite from the Wizard-AI venv
try:
    import aisuite as ai
except ImportError:
    print("Error: 'aisuite' is not installed in the current Python environment.")
    print("Please run Wizard-AI setup again to install aisuite.")
    sys.exit(1)

# Helper to load API keys from Cockpit Tools if available
def load_cockpit_tools_keys():
    # Common paths for cockpit tools configurations
    possible_paths = [
        Path.home() / ".config" / "cockpit-tools" / "config.json",
        Path.home() / ".cockpit-tools" / "config.json",
        Path.home() / ".ai-skills" / "cockpit-tools" / "config.json"
    ]
    for path in possible_paths:
        if path.exists():
            try:
                with open(path, "r") as f:
                    data = json.load(f)
                # Naively map keys to env vars if found
                keys = data.get("api_keys", {})
                for k, v in keys.items():
                    env_name = f"{k.upper()}_API_KEY"
                    if env_name not in os.environ:
                        os.environ[env_name] = v
            except Exception:
                pass

def main():
    parser = argparse.ArgumentParser(description="A/B Test a prompt across multiple models using aisuite.")
    parser.add_argument("prompt", type=str, help="The prompt to test")
    parser.add_argument("--models", type=str, nargs="+", 
                        default=["openai:gpt-4o", "anthropic:claude-3-5-sonnet-20240620"],
                        help="List of models to compare (e.g. openai:gpt-4o anthropic:claude-3-5-sonnet)")
    args = parser.parse_args()

    # Load keys from Cockpit Tools config to ensure aisuite has access
    load_cockpit_tools_keys()

    client = ai.Client()
    messages = [
        {"role": "system", "content": "You are a helpful assistant."},
        {"role": "user", "content": args.prompt}
    ]

    print("\n\033[1;36m[ai-compare] Running prompt against models:\033[0m")
    for m in args.models:
        print(f" - {m}")
    print()

    results = {}
    for model in args.models:
        print(f"\033[1;33m--- Output from {model} ---\033[0m")
        try:
            response = client.chat.completions.create(model=model, messages=messages)
            content = response.choices[0].message.content
            print(content)
        except Exception as e:
            content = f"Error: {e}"
            print(f"\033[0;31m{content}\033[0m")
        print("\n")
        results[model] = content

if __name__ == "__main__":
    main()
