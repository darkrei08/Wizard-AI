#!/usr/bin/env bash
# wz-ai-caveman — AI skill to cut output tokens by ~75% while maintaining accuracy
# Source: https://github.com/JuliusBrussee/caveman
set -euo pipefail

BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

CAVEMAN_DIR="${HOME}/.ai-skills/caveman"

show_help() {
    echo ""
    echo -e "${BOLD}${CYAN}wz-ai-caveman${RESET} — Cut AI agent output tokens by ~75%"
    echo ""
    echo -e "  Caveman is a behavioral skill that instructs the AI agent to"
    echo -e "  produce drastically shorter output while keeping 100% technical"
    echo -e "  accuracy. It works by removing filler words, unnecessary prose,"
    echo -e "  and verbose explanations."
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  wz-ai-caveman                  Show the caveman system prompt (inject into agent)"
    echo -e "  wz-ai-caveman install          Install/update caveman from source"
    echo -e "  wz-ai-caveman info             Show installation status"
    echo ""
    echo -e "${BOLD}How it works:${RESET}"
    echo -e "  Caveman is a ${BOLD}system prompt${RESET} that changes how the AI writes."
    echo -e "  It is NOT a binary that processes text — it's injected into the"
    echo -e "  agent's instructions (CLAUDE.md / AGENTS.md / GEMINI.md)."
    echo ""
    echo -e "${BOLD}Integration:${RESET}"
    echo -e "  The caveman rules are already embedded in the agent config files."
    echo -e "  When Loop 4 (Refactor & Optimize) activates token optimization,"
    echo -e "  the agent automatically applies caveman-style compressed output."
    echo ""
}

cmd_show_prompt() {
    # Try to find the caveman SKILL.md or rules
    local skill_path=""
    if [ -f "$CAVEMAN_DIR/SKILL.md" ]; then
        skill_path="$CAVEMAN_DIR/SKILL.md"
    elif [ -f "$HOME/.gemini/config/skills/caveman/SKILL.md" ]; then
        skill_path="$HOME/.gemini/config/skills/caveman/SKILL.md"
    elif [ -f "$CAVEMAN_DIR/rules/caveman.md" ]; then
        skill_path="$CAVEMAN_DIR/rules/caveman.md"
    fi

    if [ -n "$skill_path" ]; then
        echo -e "${BOLD}${CYAN}=== Caveman System Prompt (inject into AI agent) ===${RESET}"
        echo ""
        cat "$skill_path"
    else
        echo -e "${YELLOW}Caveman skill file not found. Showing built-in rules:${RESET}"
        echo ""
        echo "# Caveman Mode — Output Token Reduction (~75%)"
        echo ""
        echo "Rules for AI agent output:"
        echo "- Remove filler words (just, very, basically, essentially, actually)"
        echo "- No unnecessary prose or verbose explanations"
        echo "- Use short sentences and bullet points"
        echo "- Code speaks louder than words — show code, not paragraphs about code"
        echo "- Skip pleasantries and meta-commentary"
        echo "- Technical accuracy is 100% non-negotiable"
        echo "- When in doubt, be terser"
    fi

    # If arguments or stdin are provided, output them after
    if [ $# -gt 0 ]; then
        echo ""
        echo "$@"
    elif [ ! -t 0 ]; then
        echo ""
        cat
    fi
}

cmd_install() {
    if [ -d "$CAVEMAN_DIR" ]; then
        echo -e "${CYAN}Updating caveman from source...${RESET}"
        cd "$CAVEMAN_DIR" && git pull --ff-only 2>/dev/null || true
        echo -e "${GREEN}✓ Caveman updated at $CAVEMAN_DIR${RESET}"
    else
        echo -e "${CYAN}Cloning caveman...${RESET}"
        git clone https://github.com/JuliusBrussee/caveman.git "$CAVEMAN_DIR" 2>/dev/null || {
            echo -e "${RED}✗ Failed to clone caveman.${RESET}"
            exit 1
        }
        echo -e "${GREEN}✓ Caveman installed at $CAVEMAN_DIR${RESET}"
    fi
    # Run the original install.js if it exists
    if [ -f "$CAVEMAN_DIR/bin/install.js" ] && command -v node &>/dev/null; then
        node "$CAVEMAN_DIR/bin/install.js" 2>/dev/null || true
    fi
}

cmd_info() {
    echo -e "${BOLD}${CYAN}Caveman — Output Token Reduction (~75%)${RESET}"
    echo -e "Source: https://github.com/JuliusBrussee/caveman"
    echo -e "Type:   Behavioral skill (system prompt injection)"
    echo -e "Local:  $CAVEMAN_DIR"
    echo -e ""
    if [ -d "$CAVEMAN_DIR" ]; then
        echo -e "Status: ${GREEN}✓ installed${RESET}"
        local file_count
        file_count=$(find "$CAVEMAN_DIR" -name "*.md" | wc -l)
        echo -e "Files:  $file_count markdown files"
    else
        echo -e "Status: ${RED}✗ not installed${RESET}"
        echo -e "  Install: ${CYAN}wz-ai-caveman install${RESET}"
    fi
}

case "${1:-}" in
    install)   cmd_install ;;
    info)      cmd_info ;;
    -h|--help|help) show_help ;;
    "")        cmd_show_prompt ;;
    *)         cmd_show_prompt "$@" ;;
esac
