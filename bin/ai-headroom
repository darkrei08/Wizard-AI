#!/usr/bin/env bash
# ai-headroom — Context compression and API proxy for reducing token costs
# Source: https://github.com/chopratejas/headroom
set -euo pipefail

# Telemetry hook
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WIZARD_AI_DIR="$(dirname "$DIR")"
python3 "$WIZARD_AI_DIR/hub/api/log_event.py" "ai-headroom" "execute" 500 0.15 &

BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

HEADROOM_DIR="${HOME}/.ai-skills/headroom"

show_help() {
    echo ""
    echo -e "${BOLD}${CYAN}ai-headroom${RESET} — Context Compression & API Proxy (60-95% fewer tokens)"
    echo ""
    echo -e "  Intercepts and compresses large tool outputs, codebases, logs, or"
    echo -e "  RAG contexts before they hit the LLM's context window."
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  ai-headroom compress [--ratio N]    Compress piped input or stdin"
    echo -e "  ai-headroom proxy [--port N]        Start compression proxy server"
    echo -e "  ai-headroom status                  Show installation status"
    echo -e "  ai-headroom info                    Show installation info"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  ${CYAN}cat large_file.txt | ai-headroom compress --ratio 0.4${RESET}"
    echo -e "  ${CYAN}git log --oneline -500 | ai-headroom compress${RESET}"
    echo -e "  ${CYAN}ai-headroom proxy --port 8000${RESET}"
    echo ""
    echo -e "${BOLD}Pipeline with other tools:${RESET}"
    echo -e "  ${CYAN}command | ai-squeeze | ai-headroom compress${RESET}"
    echo -e "  ${CYAN}ai-convert doc.pdf | ai-headroom compress --ratio 0.3${RESET}"
    echo ""
}

check_binary() {
    if command -v headroom &>/dev/null; then
        return 0
    fi
    if [ -f "$HEADROOM_DIR/headroom" ]; then
        export PATH="$HEADROOM_DIR:$PATH"
        return 0
    fi
    # Check uv tool
    local uv_bin
    uv_bin="$(python3 -c "import sysconfig; print(sysconfig.get_path('scripts', 'posix_user'))" 2>/dev/null || echo "$HOME/.local/bin")"
    if [ -x "$uv_bin/headroom" ]; then
        export PATH="$uv_bin:$PATH"
        return 0
    fi
    return 1
}

cmd_compress() {
    if check_binary; then
        headroom compress "$@"
    else
        echo -e "${RED}✗ headroom not installed.${RESET}" >&2
        echo -e "  Install: ${CYAN}uv tool install headroom-ai${RESET}" >&2
        echo -e "  Or:      ${CYAN}pip install headroom-ai${RESET}" >&2
        exit 1
    fi
}

cmd_proxy() {
    if check_binary; then
        headroom proxy "$@"
    else
        echo -e "${RED}✗ headroom not installed.${RESET}" >&2
        echo -e "  Install: ${CYAN}uv tool install headroom-ai${RESET}" >&2
        exit 1
    fi
}

cmd_status() {
    echo -e "${BOLD}${CYAN}Headroom — Context Compression & API Proxy${RESET}"
    if check_binary; then
        echo -e "Binary: ${GREEN}✓ installed${RESET} ($(which headroom 2>/dev/null || echo 'local'))"
        headroom --version 2>/dev/null || true
    else
        echo -e "Binary: ${RED}✗ not installed${RESET}"
        echo -e "  Install: ${CYAN}uv tool install headroom-ai${RESET}"
    fi
    if [ -d "$HEADROOM_DIR" ]; then
        echo -e "Repo:   ${GREEN}✓ cloned${RESET} at $HEADROOM_DIR"
    else
        echo -e "Repo:   ${YELLOW}✗ not cloned${RESET}"
    fi
}

cmd_info() {
    echo -e "${BOLD}${CYAN}Headroom — Context Compression & API Proxy${RESET}"
    echo -e "Source: https://github.com/chopratejas/headroom"
    echo -e "Local:  $HEADROOM_DIR"
    echo -e ""
    echo -e "Token reduction: 60-95% on large tool outputs"
    echo -e "Modes: compress (stdin pipe), proxy (HTTP server)"
    echo -e ""
    if check_binary; then
        echo -e "Status: ${GREEN}✓ installed${RESET}"
        headroom --version 2>/dev/null || true
    else
        echo -e "Status: ${RED}✗ not installed${RESET}"
        echo -e "  Install: ${CYAN}uv tool install headroom-ai${RESET}"
    fi
}

# Handle piped input with no args → default to compress
if [[ $# -eq 0 ]] && [[ ! -t 0 ]]; then
    cmd_compress
    exit 0
fi

case "${1:-help}" in
    compress)  shift; cmd_compress "$@" ;;
    proxy)     shift; cmd_proxy "$@" ;;
    status)    cmd_status ;;
    info)      cmd_info ;;
    -h|--help|help) show_help ;;
    *) echo -e "${RED}Unknown command: $1${RESET}"; show_help; exit 1 ;;
esac
