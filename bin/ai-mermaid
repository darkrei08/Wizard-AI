#!/usr/bin/env bash
# ai-mermaid - Wrapper for @mermaid-js/mermaid-cli
# Wizard-AI Ecosystem

MERMAID_DIR="$HOME/.ai-skills/mermaid-cli"
MMDC_BIN="$MERMAID_DIR/node_modules/.bin/mmdc"

if [ ! -x "$MMDC_BIN" ]; then
  echo "❌ mermaid-cli non trovato in $MERMAID_DIR."
  echo "Assicurati di aver completato l'installazione."
  exit 1
fi

if [ "$#" -eq 0 ]; then
    echo "🧙 Wizard-AI Mermaid CLI Wrapper"
    echo "================================="
    echo "Genera diagrammi e grafici a partire da file markdown (Mermaid)."
    echo ""
    echo "Utilizzo base:"
    echo "  ai-mermaid -i input.mmd -o output.png"
    echo ""
    echo "Utilizzo avanzato:"
    echo "  ai-mermaid -i input.mmd -o output.svg -b transparent -t dark"
    echo ""
    echo "Lancio l'help originale di mmdc:"
    echo "---------------------------------"
    "$MMDC_BIN" --help
    exit 0
fi

# Execute mmdc with user arguments
"$MMDC_BIN" "$@"
