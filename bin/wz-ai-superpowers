#!/usr/bin/env bash
# wz-ai-superpowers - Wrapper for Superpowers Agentic Methodology
# Wizard-AI Ecosystem

SKILLS_DIR="$HOME/.gemini/config/skills"
LOCAL_SKILLS_DIR="$(pwd)/skills"

show_help() {
    echo "🦸 Wizard-AI Superpowers Launchpad"
    echo "================================="
    echo "Metodologia avanzata di sviluppo guidata da Sub-Agenti (Subagent-Driven Development)."
    echo "Attiva in automatico uno dei framework di lavoro:"
    echo ""
    echo "Comandi disponibili:"
    echo "  brainstorm   - Inizia una fase di raffinamento dell'idea e design socratico"
    echo "  plan         - Genera un piano di implementazione suddiviso in piccoli task (2-5 min)"
    echo "  execute      - Esegue i task tramite subagenti (TDD: Red-Green-Refactor)"
    echo "  debug        - Inizia il processo di root-cause tracing e debugging sistematico"
    echo "  review       - Richiede una code review pre-merge tramite checklist"
    echo "  finish       - Termina il branch, verifica i test e prepara per il merge"
    echo "  sync         - Sincronizza le skill di superpowers in locale (sviluppo)"
    echo ""
    echo "Esempio:"
    echo "  wz-ai-superpowers brainstorm 'Voglio creare un componente React per il login'"
}

if [ "$#" -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND=$1
shift

# Prompt costruttore per innescare i comportamenti dell'agente nel terminale
case "$COMMAND" in
    brainstorm)
        echo "🚀 Inizializzazione della skill 'brainstorming'..."
        echo "L'agente inizierà a farti domande mirate per il design di: $@"
        # In a real environment, this might trigger the AI directly via a chat interface prompt.
        ;;
    plan)
        echo "📝 Inizializzazione della skill 'writing-plans'..."
        echo "Creazione del piano dettagliato per: $@"
        ;;
    execute)
        echo "⚙️ Inizializzazione della skill 'subagent-driven-development' (TDD)..."
        echo "Esecuzione in batch dei task."
        ;;
    debug)
        echo "🐞 Inizializzazione della skill 'systematic-debugging'..."
        ;;
    review)
        echo "🔍 Inizializzazione della skill 'requesting-code-review'..."
        ;;
    finish)
        echo "🏁 Inizializzazione della skill 'finishing-a-development-branch'..."
        ;;
    sync)
        echo "🔄 Sincronizzazione delle skill di Superpowers..."
        if [ -d "$LOCAL_SKILLS_DIR/brainstorming" ]; then
            echo "Le skill sono già presenti nel progetto locale."
        else
            echo "Nessuna skill locale trovata, controllare il setup."
        fi
        ;;
    *)
        echo "❌ Comando sconosciuto: $COMMAND"
        show_help
        exit 1
        ;;
esac

exit 0
