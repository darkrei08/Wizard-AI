#!/usr/bin/env bash
# wz-ai-design — Browse and apply DESIGN.md files for AI-driven UI generation
# Source: https://github.com/VoltAgent/awesome-design-md
set -euo pipefail

# Telemetry hook
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WIZARD_AI_DIR="$(dirname "$DIR")"
python3 "$WIZARD_AI_DIR/hub/api/log_event.py" "wz-ai-design" "execute" 100 0.15 &


BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

DESIGN_DIR="${HOME}/.ai-skills/awesome-design-md"

show_help() {
    echo ""
    echo -e "${BOLD}${CYAN}wz-ai-design${RESET} — Browse DESIGN.md files for AI UI generation"
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  wz-ai-design list              List all available design systems"
    echo -e "  wz-ai-design show <name>       Show the DESIGN.md content for a brand"
    echo -e "  wz-ai-design apply <name>      Copy DESIGN.md into current project root"
    echo -e "  wz-ai-design search <query>    Search design systems by keyword"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  ${CYAN}wz-ai-design list${RESET}"
    echo -e "  ${CYAN}wz-ai-design show vercel${RESET}"
    echo -e "  ${CYAN}wz-ai-design apply cursor${RESET}"
    echo ""
}

check_installed() {
    if [ ! -d "$DESIGN_DIR" ]; then
        echo -e "${RED}✗ awesome-design-md not found at $DESIGN_DIR${RESET}"
        echo -e "  Run ${CYAN}setup.sh${RESET} or clone manually:"
        echo -e "  ${CYAN}git clone https://github.com/VoltAgent/awesome-design-md.git $DESIGN_DIR${RESET}"
        exit 1
    fi
}

cmd_list() {
    check_installed
    echo -e "${BOLD}${CYAN}Available DESIGN.md Files${RESET}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    local count=0
    for dir in "$DESIGN_DIR"/designs/*/; do
        if [ -d "$dir" ]; then
            local name
            name=$(basename "$dir")
            local has_design="❌"
            if [ -f "$dir/DESIGN.md" ]; then
                has_design="✅"
            fi
            echo -e "  $has_design  ${BOLD}$name${RESET}"
            count=$((count + 1))
        fi
    done
    # Also check root-level markdown files
    for f in "$DESIGN_DIR"/*.md; do
        if [ -f "$f" ] && [[ "$(basename "$f")" != "README.md" ]]; then
            echo -e "  📄  ${BOLD}$(basename "$f" .md)${RESET}"
            count=$((count + 1))
        fi
    done
    echo ""
    echo -e "${GREEN}$count design systems available.${RESET}"
    echo -e "Use ${CYAN}wz-ai-design show <name>${RESET} to view details."
}

cmd_show() {
    check_installed
    local name="${1:-}"
    if [ -z "$name" ]; then
        echo -e "${RED}✗ Please specify a design name. Use 'wz-ai-design list' to see options.${RESET}"
        exit 1
    fi
    local design_file="$DESIGN_DIR/designs/$name/DESIGN.md"
    if [ ! -f "$design_file" ]; then
        # Try case-insensitive match
        design_file=$(find "$DESIGN_DIR" -iname "DESIGN.md" -path "*/$name/*" 2>/dev/null | head -n1 || true)
    fi
    if [ -z "$design_file" ] || [ ! -f "$design_file" ]; then
        echo -e "${RED}✗ No DESIGN.md found for '$name'.${RESET}"
        echo -e "  Use ${CYAN}wz-ai-design list${RESET} to see available designs."
        exit 1
    fi
    echo -e "${BOLD}${CYAN}DESIGN.md — $name${RESET}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    cat "$design_file"
}

cmd_apply() {
    check_installed
    local name="${1:-}"
    if [ -z "$name" ]; then
        echo -e "${RED}✗ Please specify a design name.${RESET}"
        exit 1
    fi
    local design_file="$DESIGN_DIR/designs/$name/DESIGN.md"
    if [ ! -f "$design_file" ]; then
        design_file=$(find "$DESIGN_DIR" -iname "DESIGN.md" -path "*/$name/*" 2>/dev/null | head -n1 || true)
    fi
    if [ -z "$design_file" ] || [ ! -f "$design_file" ]; then
        echo -e "${RED}✗ No DESIGN.md found for '$name'.${RESET}"
        exit 1
    fi
    cp "$design_file" ./DESIGN.md
    echo -e "${GREEN}✓ DESIGN.md ($name) copied to $(pwd)/DESIGN.md${RESET}"
    echo -e "  AI agents will now use this design system for UI generation."
}

cmd_search() {
    check_installed
    local query="${1:-}"
    if [ -z "$query" ]; then
        echo -e "${RED}✗ Please specify a search query.${RESET}"
        exit 1
    fi
    echo -e "${BOLD}Searching for '${query}'...${RESET}"
    grep -ril "$query" "$DESIGN_DIR"/designs/ 2>/dev/null | while read -r file; do
        local dir
        dir=$(dirname "$file")
        echo -e "  📄 ${BOLD}$(basename "$dir")${RESET} — $file"
    done
}

case "${1:-help}" in
    list)    cmd_list ;;
    show)    cmd_show "${2:-}" ;;
    apply)   cmd_apply "${2:-}" ;;
    search)  cmd_search "${2:-}" ;;
    -h|--help|help) show_help ;;
    *) echo -e "${RED}Unknown command: $1${RESET}"; show_help; exit 1 ;;
esac
