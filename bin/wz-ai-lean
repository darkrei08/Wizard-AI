#!/usr/bin/env bash
# wz-ai-lean — Lean Context Intelligence for AI agents (60-90% token savings)
# Source: https://github.com/yvgude/lean-ctx
set -euo pipefail

# Telemetry hook
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WIZARD_AI_DIR="$(dirname "$DIR")"
python3 "$WIZARD_AI_DIR/hub/api/log_event.py" "wz-ai-lean" "execute" 500 0.15 &


BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

LEAN_DIR="${HOME}/.wizard-ai/lean-ctx"

show_help() {
    echo ""
    echo -e "${BOLD}${CYAN}wz-ai-lean${RESET} — Lean Context Intelligence for AI Agents"
    echo ""
    echo -e "  Controls what your AI can see. One local binary that decides what"
    echo -e "  agents read, remembers what they learn, and guards what they touch."
    echo -e "  Reduces token usage by 60-90%."
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  wz-ai-lean setup               Initialize lean-ctx for current project"
    echo -e "  wz-ai-lean status              Show context savings statistics"
    echo -e "  wz-ai-lean gain                Launch live savings dashboard"
    echo -e "  wz-ai-lean benchmark           Run compression benchmark"
    echo -e "  wz-ai-lean read <file> [mode]  Read file with compression (modes: full|map|signatures|diff)"
    echo -e "  wz-ai-lean info                Show installation info"
    echo ""
    echo -e "${BOLD}Read Modes:${RESET}"
    echo -e "  full        Complete file content"
    echo -e "  map         Structure-only overview (~13 tokens on re-read)"
    echo -e "  signatures  Function/class signatures with line spans"
    echo -e "  diff        Only changed lines since last read"
    echo -e "  density:X   Keep top X% highest-entropy lines"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  ${CYAN}wz-ai-lean setup${RESET}"
    echo -e "  ${CYAN}wz-ai-lean read src/main.py map${RESET}"
    echo -e "  ${CYAN}wz-ai-lean gain${RESET}"
    echo ""
}

check_binary() {
    if command -v lean-ctx &>/dev/null; then
        return 0
    fi
    # Check if the repo has a binary we can use
    if [ -f "$LEAN_DIR/target/release/lean-ctx" ]; then
        export PATH="$LEAN_DIR/target/release:$PATH"
        return 0
    fi
    return 1
}

cmd_setup() {
    if check_binary; then
        lean-ctx setup
    else
        echo -e "${YELLOW}lean-ctx binary not found. Attempting setup from source...${RESET}"
        if [ -d "$LEAN_DIR" ]; then
            echo -e "Source found at: $LEAN_DIR"
            if command -v cargo &>/dev/null; then
                echo -e "${CYAN}Building from source with cargo...${RESET}"
                cd "$LEAN_DIR" && cargo build --release
                echo -e "${GREEN}✓ Built lean-ctx. Run 'wz-ai-lean setup' again.${RESET}"
            else
                echo -e "${RED}✗ Neither lean-ctx binary nor cargo found.${RESET}"
                echo -e "  Install via: ${CYAN}npm install -g lean-ctx-bin${RESET}"
                echo -e "  Or:          ${CYAN}cargo install lean-ctx${RESET}"
            fi
        else
            echo -e "${RED}✗ lean-ctx not cloned. Run setup.sh first.${RESET}"
        fi
    fi
}

cmd_status() {
    if check_binary; then
        lean-ctx status 2>/dev/null || lean-ctx gain --summary 2>/dev/null || \
            echo -e "${YELLOW}No session data yet. Use 'wz-ai-lean setup' first.${RESET}"
    else
        echo -e "${RED}✗ lean-ctx not installed. Run 'wz-ai-lean setup'.${RESET}"
    fi
}

cmd_gain() {
    if check_binary; then
        lean-ctx gain "$@"
    else
        echo -e "${RED}✗ lean-ctx not installed.${RESET}"
        exit 1
    fi
}

cmd_benchmark() {
    if check_binary; then
        lean-ctx benchmark "$@"
    else
        echo -e "${RED}✗ lean-ctx not installed.${RESET}"
        exit 1
    fi
}

cmd_read() {
    local file="${1:-}"
    local mode="${2:-map}"
    if [ -z "$file" ]; then
        echo -e "${RED}✗ Specify a file to read.${RESET}"
        exit 1
    fi
    if check_binary; then
        lean-ctx read "$file" --mode "$mode"
    else
        echo -e "${RED}✗ lean-ctx not installed.${RESET}"
        exit 1
    fi
}

cmd_info() {
    echo -e "${BOLD}${CYAN}LeanCTX — Lean Context Intelligence${RESET}"
    echo -e "Repo: https://github.com/yvgude/lean-ctx"
    echo -e "Local: $LEAN_DIR"
    if check_binary; then
        echo -e "Binary: ${GREEN}✓ installed${RESET} ($(which lean-ctx 2>/dev/null || echo 'local build'))"
        lean-ctx --version 2>/dev/null || true
    else
        echo -e "Binary: ${RED}✗ not installed${RESET}"
        echo -e "  Install: ${CYAN}npm install -g lean-ctx-bin${RESET} or ${CYAN}cargo install lean-ctx${RESET}"
    fi
}

case "${1:-help}" in
    setup)     cmd_setup ;;
    status)    cmd_status ;;
    gain)      shift; cmd_gain "$@" ;;
    benchmark) shift; cmd_benchmark "$@" ;;
    read)      cmd_read "${2:-}" "${3:-map}" ;;
    info)      cmd_info ;;
    -h|--help|help) show_help ;;
    *) echo -e "${RED}Unknown command: $1${RESET}"; show_help; exit 1 ;;
esac
