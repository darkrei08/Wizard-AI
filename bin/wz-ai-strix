#!/usr/bin/env bash
# wz-ai-strix — Autonomous AI hackers that find and fix your app's vulnerabilities
# Source: https://github.com/usestrix/strix

set -euo pipefail

STRIX_BIN="${HOME}/.local/bin/strix"

show_help() {
  echo "wz-ai-strix — Strix autonomous AI pentesting tool"
  echo ""
  echo "Usage:"
  echo "  wz-ai-strix [options]           Run strix directly"
  echo "  wz-ai-strix --target <url>      Assess target URL or local repo"
  echo "  wz-ai-strix --help              Show strix help"
  echo ""
  echo "Examples:"
  echo "  wz-ai-strix --target ./app-directory"
  echo "  wz-ai-strix --target https://github.com/org/repo"
  echo "  wz-ai-strix --target https://your-app.com"
}

if [[ $# -eq 0 ]]; then
  show_help
  exit 0
fi

if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  "$STRIX_BIN" --help
  exit 0
fi

exec "$STRIX_BIN" "$@"
