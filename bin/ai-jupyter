#!/usr/bin/env bash
#
# ai-jupyter - Launches the local Wizard-AI Jupyter Server and displays the connection URL
#

JUPYTER_ENV="/home/ema/.jupyter_env"

if [ ! -f "$JUPYTER_ENV/bin/jupyter" ]; then
    echo "❌ Error: Jupyter environment not found at $JUPYTER_ENV" >&2
    exit 1
fi

echo "======================================================================"
echo "✨ LAUNCHING WIZARD-AI LOCAL JUPYTER SERVER..."
echo "======================================================================"
echo "When VS Code / IDE asks for 'Quale URL metto?' (Existing Server URL):"
echo "Copy and paste the http://127.0.0.1:8888/?token=... URL shown below!"
echo "======================================================================"
echo ""

exec "$JUPYTER_ENV/bin/jupyter" notebook --no-browser --port 8888 --ip 127.0.0.1
