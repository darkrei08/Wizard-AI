#!/usr/bin/env bash
# ai-vector - Universal command-line RAG indexing using Turbovec
# Wizard-AI Ecosystem
set -e

VENV="$HOME/.ai-skills/venv"

if [ ! -d "$VENV" ]; then
  echo "❌ Virtual environment non trovato in $VENV."
  echo "Per favore esegui 'sudo ./setup.sh' per installarlo."
  exit 1
fi

exec "$VENV/bin/python" - "$@" << 'EOF'
import sys
import json
import argparse
import os

try:
    import numpy as np
    import turbovec
    import litellm
except ImportError as e:
    print(f"❌ Errore di importazione: {e}")
    print("Assicurati di aver compilato turbovec eseguendo l'aggiornamento di Wizard-AI.")
    print("Ricorda di installare i compilatori di sistema (es. rust, openblas).")
    sys.exit(1)

# Disable verbose litellm logging
litellm.suppress_debug_info = True

# We use text-embedding-3-small by default or nomic via ollama
# Note: user must have OPENAI_API_KEY set or use an alternative provider like ollama
DEFAULT_MODEL = os.environ.get("AI_VECTOR_MODEL", "text-embedding-3-small")

def get_embedding(text):
    try:
        response = litellm.embedding(model=DEFAULT_MODEL, input=text)
        emb = response.data[0]['embedding']
        # turbovec requires numpy arrays
        return np.array(emb, dtype=np.float32)
    except Exception as e:
        print(f"❌ Errore durante l'estrazione dell'embedding: {e}")
        sys.exit(1)

def init_db(db_path, dim, bit_width):
    if not os.path.exists(db_path):
        os.makedirs(db_path)
    
    index_file = os.path.join(db_path, "turbovec.index")
    docs_file = os.path.join(db_path, "docs.json")
    
    if os.path.exists(docs_file):
        print(f"⚠️ Il database esiste già in {db_path}")
        return
        
    index = turbovec.IdMapIndex(dim=dim, bit_width=bit_width)
    index.save(index_file)
    
    with open(docs_file, "w") as f:
        json.dump({"docs": [], "dim": dim, "bit_width": bit_width}, f)
        
    print(f"✅ Inizializzato RAG turbovec in {db_path} (dim={dim}, bit={bit_width})")

def add_doc(db_path, text):
    index_file = os.path.join(db_path, "turbovec.index")
    docs_file = os.path.join(db_path, "docs.json")
    
    if not os.path.exists(docs_file):
        print(f"❌ Database non trovato in {db_path}. Esegui 'init' prima.")
        sys.exit(1)
        
    with open(docs_file, "r") as f:
        data = json.load(f)
        
    dim = data.get("dim")
    
    print(f"Generazione embedding usando {DEFAULT_MODEL}...")
    vec = get_embedding(text)
    # Ensure it is a 2D array [1, dim]
    vec_2d = vec.reshape(1, -1)
    
    # Load index
    index = turbovec.IdMapIndex.load(index_file)
    
    # Add to index (ID is length of current docs)
    doc_id = len(data["docs"])
    ids = np.array([doc_id], dtype=np.uint64)
    
    # Add vector
    index.add_with_ids(vec_2d, ids)
    index.save(index_file)
    
    # Save text
    data["docs"].append({"id": doc_id, "text": text})
    with open(docs_file, "w") as f:
        json.dump(data, f, indent=2)
        
    print(f"✅ Documento aggiunto con successo! (ID: {doc_id})")

def search_docs(db_path, query, top_k):
    index_file = os.path.join(db_path, "turbovec.index")
    docs_file = os.path.join(db_path, "docs.json")
    
    if not os.path.exists(docs_file):
        print(f"❌ Database non trovato in {db_path}.")
        sys.exit(1)
        
    with open(docs_file, "r") as f:
        data = json.load(f)
        
    if not data["docs"]:
        print("Il database è vuoto.")
        return
        
    print(f"🔎 Ricerca semantica per: '{query}'...")
    vec = get_embedding(query)
    vec_2d = vec.reshape(1, -1)
    
    index = turbovec.IdMapIndex.load(index_file)
    k = min(top_k, len(data["docs"]))
    
    # Search
    distances, ids = index.search(vec_2d, k)
    
    print("\n✅ Risultati trovati:")
    for dist, doc_id in zip(distances[0], ids[0]):
        # Match ID
        doc_text = next((d["text"] for d in data["docs"] if d["id"] == doc_id), "Sconosciuto")
        print(f"[{dist:.4f}] {doc_text}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Wizard-AI Universal RAG CLI powered by Turbovec")
    subparsers = parser.add_subparsers(dest="action", required=True)
    
    # Init
    p_init = subparsers.add_parser("init", help="Inizializza un nuovo database")
    p_init.add_argument("db_path", help="Percorso della directory del DB")
    p_init.add_argument("--dim", type=int, default=1536, help="Dimensione embedding (1536 per OpenAI)")
    p_init.add_argument("--bit", type=int, default=4, help="Bit width di quantizzazione (2 o 4)")
    
    # Add
    p_add = subparsers.add_parser("add", help="Aggiunge testo al database")
    p_add.add_argument("db_path", help="Percorso della directory del DB")
    p_add.add_argument("text", help="Il testo da aggiungere")
    
    # Search
    p_search = subparsers.add_parser("search", help="Cerca semanticamente nel database")
    p_search.add_argument("db_path", help="Percorso della directory del DB")
    p_search.add_argument("query", help="Query di ricerca")
    p_search.add_argument("-k", type=int, default=3, help="Numero di risultati")
    
    args = parser.parse_args()
    
    if args.action == "init":
        init_db(args.db_path, args.dim, args.bit)
    elif args.action == "add":
        add_doc(args.db_path, args.text)
    elif args.action == "search":
        search_docs(args.db_path, args.query, args.k)

EOF
