  echo -e "  вњ… ${BOLD}serena${RESET}           Semantic code search & LSP navigation (MCP + CLI)"
else
  echo -e "  вќЊ ${BOLD}serena${RESET}           Semantic code search (install: uv tool install serena)"
fi
echo -e "     ${BLUE}serena find-usages MyClass${RESET}"
