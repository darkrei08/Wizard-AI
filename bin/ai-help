echo -e "${BOLD}${YELLOW}рџ”§ CONTEXT & SCAFFOLDING${RESET}"
echo -e "  $(check_cmd ai-lean) ${BOLD}ai-lean${RESET}           Lean Context Intelligence (60-90% token savings)"
echo -e "     ${BLUE}ai-lean read src/main.py map${RESET}"
