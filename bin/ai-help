echo -e "${BOLD}${YELLOW}рџ“љ KNOWLEDGE BUILDING${RESET}"
echo -e "  $(check_cmd book-to-skill) ${BOLD}book-to-skill${RESET}    Convert books/PDFs into AI skills"
echo -e "     ${BLUE}book-to-skill document.pdf${RESET}"
