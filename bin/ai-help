echo -e "${BOLD}${YELLOW}рџЊђ LLM GATEWAY${RESET}"
echo -e "  $(check_cmd litellm) ${BOLD}litellm${RESET}          Unified API for 100+ LLM providers + cost tracking"
echo -e "     ${BLUE}litellm --model gemini/gemini-2.0-flash --port 4000${RESET}"
