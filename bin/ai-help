echo -e "${BOLD}${YELLOW}рџ“€ USAGE & MONITORING${RESET}"
echo -e "  $(check_cmd ai-usage) ${BOLD}ai-usage${RESET}          Track Gemini CLI token/context usage"
echo -e "     ${BLUE}ai-usage${RESET}"
echo -e "  $(check_cmd ai-quota) ${BOLD}ai-quota${RESET}          View AI provider quotas and subscriptions"
echo -e "     ${BLUE}ai-quota${RESET}"
