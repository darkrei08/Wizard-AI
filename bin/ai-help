echo -e "${BOLD}${YELLOW}вљ™пёЏ  FRAMEWORK${RESET}"
if [ -d "$HOME/.ai-skills/ECC" ]; then
  ECC_SKILLS=$(ls ~/.ai-skills/ECC/skills/ 2>/dev/null | wc -l)
  echo -e "  вњ… ${BOLD}ECC${RESET}              $ECC_SKILLS+ production-ready agent skills & hooks"
else
  echo -e "  вќЊ ${BOLD}ECC${RESET}              Agent skills framework (not installed)"
fi
echo -e "     ${BLUE}ls ~/.ai-skills/ECC/skills/${RESET}"
echo ""

echo -e "${BOLD}${MAGENTA}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"
echo -e "${BOLD}Skills directory:${RESET} ~/.gemini/config/skills/"
