#!/usr/bin/env bash
# ai-help — Central hub for all AI tools and skills
# Shows all available AI CLI tools with descriptions and usage hints

set -euo pipefail

BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
RESET='\033[0m'

check_cmd() {
  command -v "$1" &>/dev/null && echo "✅" || echo "❌"
}

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${CYAN}║         🤖  AI Tools & Skills Hub — $(hostname)        ║${RESET}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════╝${RESET}"
echo ""

echo -e "${BOLD}${RED}⚡ PRE-INSTALL GATE — Always use ai-os before installing anything${RESET}"
echo -e "  $(check_cmd ai-os) ${BOLD}ai-os${RESET}            Universal OS-aware installer (os-detect skill)"
echo -e "     ${BLUE}ai-os info                     ${RESET}→ full OS/distro/PM/tool environment report"
echo -e "     ${BLUE}ai-os install <pkg>            ${RESET}→ system package via pacman|apt|dnf|brew|winget…"
echo -e "     ${BLUE}ai-os ensure git gh jq         ${RESET}→ install multiple tools only if missing"
echo -e "     ${BLUE}ai-os python ruff              ${RESET}→ Python tool via uv tool install"
echo -e "     ${BLUE}ai-os node prettier            ${RESET}→ Node.js tool via npm/pnpm"
echo -e "     ${BLUE}ai-os cargo bat                ${RESET}→ Rust crate via cargo install"
echo -e "     ${BLUE}ai-os pre-check                ${RESET}→ validate environment before any install"
echo -e "     ${BLUE}ai-os gh-setup                 ${RESET}→ GitHub CLI install + auth in one command"
echo ""

echo -e "${BOLD}${YELLOW}🚀 GIT DEVOPS — Auto-Release, Branch & Debug${RESET}"
echo -e "  $(check_cmd ai-release) ${BOLD}ai-release${RESET}       Semantic versioning + GitHub releases (auto-release)"
echo -e "     ${BLUE}ai-release minor               ${RESET}→ bump MINOR, tag, push, publish GitHub release"
echo -e "     ${BLUE}ai-release patch --dry-run     ${RESET}→ preview only, no changes"
echo -e "     ${BLUE}ai-release v2.0.0 --draft      ${RESET}→ create draft release"
echo ""
echo -e "  $(check_cmd ai-branch) ${BOLD}ai-branch${RESET}        Automated branch lifecycle management (auto-branch)"
echo -e "     ${BLUE}ai-branch feature \"my feature\" ${RESET}→ create feature/<slug> from main"
echo -e "     ${BLUE}ai-branch merge                ${RESET}→ pre-merge checks + merge to main"
echo -e "     ${BLUE}ai-branch list                 ${RESET}→ branch status report"
echo ""
echo -e "  $(check_cmd ai-debug) ${BOLD}ai-debug${RESET}         Spec-kit: lint + format + test + secret scan (auto-debug)"
echo -e "     ${BLUE}ai-debug check                 ${RESET}→ full quality gate"
echo -e "     ${BLUE}ai-debug check --fix           ${RESET}→ full gate + auto-correct"
echo -e "     ${BLUE}ai-debug log --errors          ${RESET}→ inspect SQLite debug log"
echo ""
echo -e "  $(check_cmd ai-npm-setup) ${BOLD}ai-npm-setup${RESET}     NPM Publish Setup: configure tokens & check workflows"
echo -e "     ${BLUE}ai-npm-setup                   ${RESET}→ check npm secrets & GitHub actions"
echo ""

echo -e "${BOLD}${YELLOW}📊 KNOWLEDGE GRAPH${RESET}"
echo -e "  $(check_cmd graphify) ${BOLD}graphify${RESET}         Build knowledge graphs from any codebase/docs"
echo -e "     ${BLUE}ai-graph .${RESET}                  → Run Graphify on current directory"
echo -e "     ${BLUE}graphify query \"how does X work?\"${RESET}"
echo -e "  ✅ ${BOLD}auto-graphify${RESET}    Behavioral hook to auto-update codebase graph"
echo ""

echo -e "${BOLD}${YELLOW}🗜️  TOKEN OPTIMIZATION${RESET}"
echo -e "  $(check_cmd ai-optimize) ${BOLD}ai-optimize${RESET}      Token optimization loop and skill evaluator (auto-optimize)"
echo -e "     ${BLUE}ai-optimize loop \"my task\"${RESET}"
echo -e "     ${BLUE}ai-optimize evaluate \"https://github.com/author/repo\"${RESET}"
echo -e "  $(check_cmd ai-compress) ${BOLD}ai-compress${RESET}      Compress prompts/context up to 20x (LLMLingua)"
echo -e "     ${BLUE}ai-compress --file doc.txt --ratio 0.5${RESET}"
echo -e "  $(check_cmd ai-caveman) ${BOLD}ai-caveman${RESET}       Cut agent output tokens by ~75% while keeping accuracy"
echo -e "     ${BLUE}ai-caveman --with-init${RESET}"
echo -e "  $(check_cmd ai-ponytail) ${BOLD}ai-ponytail${RESET}      Acts as a lazy senior dev to prevent over-engineering (YAGNI)"
echo -e "     ${BLUE}ai-ponytail \"write a datepicker\"${RESET}"
echo -e "  $(check_cmd ai-rerank) ${BOLD}ai-rerank${RESET}        Re-rank passages by relevance (FlashRank RAG)"
echo -e "     ${BLUE}ai-rerank --query \"X\" --passages docs.json${RESET}"
echo -e "  $(check_cmd sqz) ${BOLD}sqz${RESET}              Compress CLI output / JSON / logs"
echo -e "     ${BLUE}command | ai-squeeze${RESET}"
echo -e "  $(check_cmd markitdown) ${BOLD}markitdown${RESET}       Convert any file to Markdown for LLM ingestion"
echo -e "     ${BLUE}ai-convert document.pdf${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}🌐 LLM GATEWAY${RESET}"
echo -e "  $(check_cmd litellm) ${BOLD}litellm${RESET}          Unified API for 100+ LLM providers + cost tracking"
echo -e "     ${BLUE}litellm --model gemini/gemini-2.0-flash --port 4000${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}📈 USAGE & MONITORING${RESET}"
echo -e "  $(check_cmd ai-usage) ${BOLD}ai-usage${RESET}          Track Gemini CLI token/context usage"
echo -e "     ${BLUE}ai-usage${RESET}"
echo -e "  $(check_cmd ai-quota) ${BOLD}ai-quota${RESET}          View AI provider quotas and subscriptions"
echo -e "     ${BLUE}ai-quota${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}🎨 DESIGN & FRONTEND${RESET}"
echo -e "  $(check_cmd ai-design) ${BOLD}ai-design${RESET}         Browse & apply DESIGN.md files for UI generation"
echo -e "     ${BLUE}ai-design apply vercel${RESET}"
echo -e "  $(check_cmd ai-taste) ${BOLD}ai-taste${RESET}          Apply anti-slop frontend design skill"
echo -e "     ${BLUE}ai-taste install${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}🔧 CONTEXT & SCAFFOLDING${RESET}"
echo -e "  $(check_cmd ai-lean) ${BOLD}ai-lean${RESET}           Lean Context Intelligence (60-90% token savings)"
echo -e "     ${BLUE}ai-lean read src/main.py map${RESET}"
echo -e "  $(check_cmd ai-scaffold) ${BOLD}ai-scaffold${RESET}       Scaffold Express/Nuxt projects from templates"
echo -e "     ${BLUE}ai-scaffold nuxt my-app${RESET}"
echo -e "  $(check_cmd ai-rtk) ${BOLD}ai-rtk${RESET}            RTK AI toolkit"
echo -e "     ${BLUE}ai-rtk --help${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}🧠 MEMORY & CONTEXT${RESET}"
if [ -d "$HOME/.ai-skills/claude-mem" ]; then
  echo -e "  ✅ ${BOLD}claude-mem${RESET}       Persistent semantic memory across sessions"
else
  echo -e "  ❌ ${BOLD}claude-mem${RESET}       Persistent semantic memory (not installed)"
fi
echo -e "     ${BLUE}ai-mem store \"user prefers Python\"${RESET}"
echo -e "     ${BLUE}ai-mem search \"tech preferences\"${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}🔍 CODE INTELLIGENCE${RESET}"
if command -v serena &>/dev/null; then
  echo -e "  ✅ ${BOLD}serena${RESET}           Semantic code search & LSP navigation (MCP + CLI)"
else
  echo -e "  ❌ ${BOLD}serena${RESET}           Semantic code search (install: uv tool install serena)"
fi
echo -e "     ${BLUE}serena find-usages MyClass${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}📚 KNOWLEDGE BUILDING${RESET}"
echo -e "  $(check_cmd book-to-skill) ${BOLD}book-to-skill${RESET}    Convert books/PDFs into AI skills"
echo -e "     ${BLUE}book-to-skill document.pdf${RESET}"
echo ""

echo -e "${BOLD}${YELLOW}⚙️  FRAMEWORK${RESET}"
if [ -d "$HOME/.ai-skills/ECC" ]; then
  ECC_SKILLS=$(ls ~/.ai-skills/ECC/skills/ 2>/dev/null | wc -l)
  echo -e "  ✅ ${BOLD}ECC${RESET}              $ECC_SKILLS+ production-ready agent skills & hooks"
else
  echo -e "  ❌ ${BOLD}ECC${RESET}              Agent skills framework (not installed)"
fi
echo -e "     ${BLUE}ls ~/.ai-skills/ECC/skills/${RESET}"
echo ""

echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${BOLD}Skills directory:${RESET} ~/.gemini/config/skills/"
echo -e "${BOLD}Tools directory:${RESET}  ~/.ai-skills/"
echo -e "${BOLD}CLIs:${RESET}             ~/.local/bin/ | ~/.wizard-ai/bin/"
echo ""
echo -e "${CYAN}Tip: all tools work as pipes → cmd | ai-compress | ai-rerank${RESET}"
echo -e "${CYAN}Tip: use 'ai-branch feature <desc>' to start a feature, 'ai-branch merge' to merge${RESET}"
echo ""
