#!/usr/bin/env bash
# ==============================================================================
# wz-ai-loop-sentinel — Systemic Loop Interceptor & MoE Task Weight Gating
# Part of Wizard-AI Definitive Autonomous Engine (v0.44.0)
# ==============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"

# Terminal Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
PURPLE='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

function show_banner() {
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD} 🧙 WIZARD-AI LOOP SENTINEL — MoE Task Weight Classification & Router ${NC}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════════${NC}"
}

function calculate_and_route() {
    local input_text="$1"
    echo -e "${YELLOW}🔍 Analisi prompt / input naturale:${NC} \"$input_text\""

    local weight="LIGHT"
    local score="0.2"
    local target_loop="Esclusione Loop (Esecuzione Diretta / LIGHT)"
    local active_skills="pi-dev (native fast execution)"

    # Keyword matching for MoE Weight Classification
    shopt -s nocasematch
    if [[ "$input_text" =~ (architettura|refactor|migrazione|progetto|release|deploy|security|pentest|scaffold|bootstrap|tdd|feature complessa) ]]; then
        weight="HEAVY"
        score="0.95"
        target_loop="01. loop-1-plan → 02. loop-2-develop → 03. loop-3-debug → 04. loop-4-refactor → 05. loop-5-release"
        active_skills="prompt-loop-engine, auto-router, pi-dev (AST Pruning + Sharding), workflow-agentic-brain, master-project-bootstrap"
    elif [[ "$input_text" =~ (debug|bug|errore|crash|broken|fix|issue|verify|test) ]]; then
        weight="HEAVY (Debug Chain)"
        score="0.85"
        target_loop="03. loop-3-debug → 04. loop-4-refactor → 05. loop-5-release"
        active_skills="mp-diagnosing-bugs, systematic-debugging, verification-before-completion, pi-dev"
    elif [[ "$input_text" =~ (ui|design|layout|premium|stitch|taste|theme) ]]; then
        weight="MEDIUM→HEAVY"
        score="0.65"
        target_loop="workflow-frontend-design + 04. loop-4-refactor"
        active_skills="taste-skill, awesome-design, impeccable, stitch-taste-design, theme-factory"
    elif [[ "$input_text" =~ (seo|blog|ricerca|nicchia|marketing) ]]; then
        weight="MEDIUM"
        score="0.55"
        target_loop="workflow-seo-research"
        active_skills="claude-seo, claude-blog, last30days, firecrawl"
    elif [[ "$input_text" =~ (immagini|arte|infografica|chart|poster|mermaid|diagramma) ]]; then
        weight="MEDIUM"
        score="0.50"
        target_loop="canvas-design / mermaid-cli + graphify"
        active_skills="algorithmic-art, canvas-design, infographic, mermaid-cli, graphify"
    fi
    shopt -u nocasematch

    echo -e "${PURPLE}${BOLD}⚖️  MoE Task Weight Classification:${NC} ${BOLD}$weight (Score: $score)${NC}"
    echo -e "${GREEN}${BOLD}🔀 Active Loop Pipeline:${NC} $target_loop"
    echo -e "${CYAN}${BOLD}🛠️  Categorized Skills Bound:${NC} $active_skills"
    echo -e "${CYAN}🗜️  Context Rule Applied:${NC} Tree-sitter AST Pruning active (loading only signatures & metadata via pi.dev wrapper)."
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════════${NC}\n"
}

# Main Execution
if [[ "${1:-}" == "--check" || "${1:-}" == "" ]]; then
    show_banner
    echo -e "${GREEN}✅ Systemic Loop Sentinel attivo e agganciato al filesystem e agli hook di esecuzione.${NC}"
    calculate_and_route "Verifica di sistema o esecuzione pre-commit"
    exit 0
elif [[ "${1:-}" == "--prompt" ]]; then
    shift
    show_banner
    calculate_and_route "$*"
    exit 0
else
    show_banner
    calculate_and_route "$*"
    exit 0
fi
