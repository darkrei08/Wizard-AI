#!/usr/bin/env bash
# wz-ai-npm-setup — Interactive setup for NPM tokens and workflow checks
set -euo pipefail

BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RESET='\033[0m'

echo -e "${BOLD}${CYAN}📦 NPM Publish & GitHub Setup Wizard${RESET}"
echo ""

# 1. NPM Token check
if gh secret list | grep -q "NPM_TOKEN"; then
    echo -e "✅ NPM_TOKEN secret is already set in GitHub."
else
    echo -e "${YELLOW}⚠️ NPM_TOKEN is missing in GitHub secrets.${RESET}"
    echo "To set it up:"
    echo "1. Go to https://www.npmjs.com/settings/tokens"
    echo "2. Generate a new 'Automation' token"
    echo "3. Run this command manually to save it:"
    echo -e "   ${CYAN}gh secret set NPM_TOKEN${RESET} (it will prompt you to paste the token)"
    echo ""
fi

# 2. Package.json check
if [ -f "package.json" ]; then
    VERSION=$(grep -m1 '"version"' package.json | cut -d'"' -f4)
    echo -e "✅ package.json found. Current version: ${BOLD}$VERSION${RESET}"
    echo -e "   ${YELLOW}Remember to bump this version before running wz-ai-release!${RESET}"
else
    echo -e "⚠️ No package.json found in the current directory."
fi

# 3. GitHub Actions Deprecation Check
echo ""
echo -e "${BOLD}🔍 Checking GitHub Actions for outdated Node.js versions...${RESET}"
if ls .github/workflows/*.yml 1> /dev/null 2>&1; then
    if grep -q "node-version: 20" .github/workflows/*.yml; then
        echo -e "${YELLOW}⚠️ Warning: Found 'node-version: 20' in workflows. Consider updating to 22 or 24.${RESET}"
        grep -n "node-version: 20" .github/workflows/*.yml
    else
        echo -e "✅ No outdated Node 20 versions found in workflows."
    fi
else
    echo -e "ℹ️ No GitHub workflows found."
fi

echo ""
echo -e "${GREEN}Setup checks completed!${RESET}"
