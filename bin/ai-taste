#!/usr/bin/env bash
# ai-taste — Apply anti-slop frontend design skills for premium AI-built UIs
# Source: https://github.com/leonxlnx/taste-skill
set -euo pipefail

# Telemetry hook
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WIZARD_AI_DIR="$(dirname "$DIR")"
python3 "$WIZARD_AI_DIR/hub/api/log_event.py" "ai-taste" "execute" 100 0.15 &


BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

TASTE_DIR="${HOME}/.ai-skills/taste-skill"

show_help() {
    echo ""
    echo -e "${BOLD}${CYAN}ai-taste${RESET} — Anti-Slop Frontend Framework for AI Agents"
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  ai-taste list               List available taste skills"
    echo -e "  ai-taste install [skill]    Install a skill into current project"
    echo -e "  ai-taste show <skill>       Show the SKILL.md content"
    echo -e "  ai-taste info               Show repo info and version"
    echo ""
    echo -e "${BOLD}Install Names:${RESET}"
    echo -e "  ${CYAN}design-taste-frontend${RESET}     v2 (default) — layout, typography, motion"
    echo -e "  ${CYAN}design-taste-frontend-v1${RESET}  v1 — original version"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  ${CYAN}ai-taste list${RESET}"
    echo -e "  ${CYAN}ai-taste install${RESET}           # installs default skill to ./skills/"
    echo -e "  ${CYAN}npx skills add https://github.com/Leonxlnx/taste-skill${RESET}"
    echo ""
}

check_installed() {
    if [ ! -d "$TASTE_DIR" ]; then
        echo -e "${RED}✗ taste-skill not found at $TASTE_DIR${RESET}"
        echo -e "  Run ${CYAN}setup.sh${RESET} or clone manually:"
        echo -e "  ${CYAN}git clone https://github.com/leonxlnx/taste-skill.git $TASTE_DIR${RESET}"
        exit 1
    fi
}

cmd_list() {
    check_installed
    echo -e "${BOLD}${CYAN}Available Taste Skills${RESET}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    for dir in "$TASTE_DIR"/skills/*/; do
        if [ -d "$dir" ]; then
            local name
            name=$(basename "$dir")
            local skill_file="$dir/SKILL.md"
            if [ -f "$skill_file" ]; then
                local desc
                desc=$(head -10 "$skill_file" | grep -i "description:" | sed 's/.*description: *"\{0,1\}//' | sed 's/"\{0,1\} *$//' || echo "No description")
                echo -e "  ✅ ${BOLD}$name${RESET}"
                echo -e "     ${desc}"
            else
                echo -e "  📁 ${BOLD}$name${RESET} (no SKILL.md)"
            fi
        fi
    done
    echo ""
    echo -e "Install via: ${CYAN}npx skills add https://github.com/Leonxlnx/taste-skill${RESET}"
}

cmd_install() {
    check_installed
    local skill="${1:-}"
    local target_dir="./skills"
    mkdir -p "$target_dir"

    if [ -z "$skill" ]; then
        # Install default (taste-skill main SKILL.md)
        local main_skill="$TASTE_DIR/skills/taste-skill/SKILL.md"
        if [ -f "$main_skill" ]; then
            mkdir -p "$target_dir/taste-skill"
            cp "$main_skill" "$target_dir/taste-skill/SKILL.md"
            echo -e "${GREEN}✓ taste-skill (design-taste-frontend) installed to $target_dir/taste-skill/${RESET}"
        else
            echo -e "${YELLOW}⚠ Default skill not found. Copying all available skills...${RESET}"
            cp -r "$TASTE_DIR/skills/"* "$target_dir/" 2>/dev/null || true
            echo -e "${GREEN}✓ All taste skills copied to $target_dir/${RESET}"
        fi
    else
        local skill_dir="$TASTE_DIR/skills/$skill"
        if [ -d "$skill_dir" ]; then
            mkdir -p "$target_dir/$skill"
            cp -r "$skill_dir/"* "$target_dir/$skill/"
            echo -e "${GREEN}✓ $skill installed to $target_dir/$skill/${RESET}"
        else
            echo -e "${RED}✗ Skill '$skill' not found. Use 'ai-taste list'.${RESET}"
            exit 1
        fi
    fi
}

cmd_show() {
    check_installed
    local skill="${1:-taste-skill}"
    local skill_file="$TASTE_DIR/skills/$skill/SKILL.md"
    if [ ! -f "$skill_file" ]; then
        echo -e "${RED}✗ SKILL.md not found for '$skill'.${RESET}"
        exit 1
    fi
    cat "$skill_file"
}

cmd_info() {
    check_installed
    echo -e "${BOLD}${CYAN}Taste Skill${RESET} — Anti-Slop Frontend Framework"
    echo -e "Path: ${TASTE_DIR}"
    echo -e "Repo: https://github.com/leonxlnx/taste-skill"
    local count
    count=$(find "$TASTE_DIR/skills" -name "SKILL.md" 2>/dev/null | wc -l)
    echo -e "Skills available: ${count}"
    if [ -f "$TASTE_DIR/CHANGELOG.md" ]; then
        echo -e "Latest: $(head -5 "$TASTE_DIR/CHANGELOG.md" | grep -E "^#" | head -1 || echo 'unknown')"
    fi
}

case "${1:-help}" in
    list)    cmd_list ;;
    install) cmd_install "${2:-}" ;;
    show)    cmd_show "${2:-}" ;;
    info)    cmd_info ;;
    -h|--help|help) show_help ;;
    *) echo -e "${RED}Unknown command: $1${RESET}"; show_help; exit 1 ;;
esac
