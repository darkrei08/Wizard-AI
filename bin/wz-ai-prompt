#!/usr/bin/env bash
# wz-ai-prompt — Convert raw natural language to structured XML prompts
# Source: Wizard-AI skill (auto-prompt)
# Uses Simon Willison's `llm` CLI for routing and structuring.

set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
DIM='\033[2m'
RESET='\033[0m'

usage() {
  echo -e "${BOLD}Usage:${RESET} wz-ai-prompt <\"raw text\"> | -f <file.txt> [--critical]"
  echo -e "Converts messy natural language into a highly structured XML prompt."
  exit 1
}

if ! command -v llm &>/dev/null; then
  echo -e "${RED}❌ 'llm' CLI not found.${RESET}"
  echo -e "   Install it with: pipx install llm (or via wz-ai-os)"
  exit 1
fi

CRITICAL=false
RAW_TEXT=""

while [[ $# -gt 0 ]]; do
  case $1 in
    -f|--file)
      if [[ -n "${2:-}" && -f "$2" ]]; then
        RAW_TEXT=$(cat "$2")
        shift 2
      else
        echo -e "${RED}❌ Error: File not found or not provided.${RESET}"
        exit 1
      fi
      ;;
    --critical)
      CRITICAL=true
      shift
      ;;
    -h|--help)
      usage
      ;;
    *)
      if [[ -z "$RAW_TEXT" ]]; then
        RAW_TEXT="$1"
      else
        RAW_TEXT="$RAW_TEXT $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$RAW_TEXT" ]]; then
  usage
fi

# ── Dynamic Model Routing (based on policy.yml) ──────────────────────────────
# We use a word count heuristic (words * 1.3 ≈ tokens) to determine threshold.
WORDS=$(echo "$RAW_TEXT" | wc -w)
APPROX_TOKENS=$((WORDS * 13 / 10))

LARGE_CTX_THRESHOLD=8000

if $CRITICAL; then
  MODEL="claude-opus-latest"
  FALLBACK="gpt-5-omni-latest"
  FALLBACK2="o4-mini"
  STRATEGY="critical"
elif [[ "$APPROX_TOKENS" -gt "$LARGE_CTX_THRESHOLD" ]]; then
  MODEL="gemini-pro-latest"
  FALLBACK="claude-sonnet-latest"
  FALLBACK2="qwen-max-latest"
  STRATEGY="large_context"
else
  MODEL="gemini-flash-latest"
  FALLBACK="claude-haiku-latest"
  FALLBACK2="gpt-5o-mini-latest"
  STRATEGY="primary (fast)"
fi

echo -e "${CYAN}🤖 Analyzing prompt (${APPROX_TOKENS} tokens)...${RESET}" >&2
echo -e "${DIM}   Routing strategy: ${STRATEGY} | Model: ${MODEL}${RESET}" >&2

# ── Construct the Meta-Prompt ────────────────────────────────────────────────
# Path to the base XML template
WIZARD_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BASE_TEMPLATE_PATH="$WIZARD_DIR/skills/auto-prompt/templates/base.xml"

if [[ -f "$BASE_TEMPLATE_PATH" ]]; then
  TEMPLATE_GUIDE="Usa questa struttura XML esatta come base:\n$(cat "$BASE_TEMPLATE_PATH")"
else
  TEMPLATE_GUIDE="Devi strutturare l'output usando tag XML: <system_instructions>, <context>, <rules>, <skills>, <task>."
fi

META_PROMPT="Sei un Prompt Engineer Senior. Il tuo obiettivo è prendere un input testuale grezzo fornito da un utente umano (che potrebbe essere impreciso o disordinato) e riscriverlo in un prompt perfetto, strutturato e modulare in formato XML.

${TEMPLATE_GUIDE}

Istruzioni per la riscrittura:
1. Estrapola l'intento principale e mettilo in <task>.
2. Se l'utente menziona codice o percorsi, mettili in <context>.
3. Deduci le regole implicite (es. non rompere funzionalità esistenti) in <rules>.
4. Compila dinamicamente <dynamic_skills> con le skill pertinenti (es. auto-debug se è un bug, auto-optimize se richiede ottimizzazione).
5. Restituisci SOLO l'XML finale. Nessun preambolo, nessuna spiegazione.

INPUT GREZZO DELL'UTENTE:
${RAW_TEXT}"

# ── Execute via llm CLI ──────────────────────────────────────────────────────
execute_llm() {
  local target_model="$1"
  local prompt_text="$2"
  
  OUTPUT=$(llm -m "$target_model" "$prompt_text" 2>/dev/null)
  
  # Simple local XML validation
  if [[ "$OUTPUT" == *"<task>"* || "$OUTPUT" == *"<system_instructions>"* ]]; then
    echo "$OUTPUT"
    return 0
  else
    return 1
  fi
}

echo -e "${CYAN}🤖 [Fase 1] Strutturazione base del prompt XML...${RESET}" >&2

XML_DRAFT=""
if XML_DRAFT=$(execute_llm "$MODEL" "$META_PROMPT"); then
  true
elif XML_DRAFT=$(execute_llm "$FALLBACK" "$META_PROMPT"); then
  echo -e "${YELLOW}⚠️  Model $MODEL failed. Used $FALLBACK.${RESET}" >&2
elif XML_DRAFT=$(execute_llm "$FALLBACK2" "$META_PROMPT"); then
  echo -e "${YELLOW}⚠️  Used $FALLBACK2.${RESET}" >&2
else
  echo -e "${RED}❌ All models failed for Phase 1.${RESET}" >&2
  exit 1
fi

# ── Extract Intents for Memory ────────────────────────────────────────────────
EXTRACTED=$(python3 -c "
import re, sys
xml = sys.stdin.read()
task = re.search(r'<task>(.*?)</task>', xml, re.DOTALL)
rules = re.search(r'<rules>(.*?)</rules>', xml, re.DOTALL)
t_str = task.group(1).strip().replace('\n', ' ') if task else ''
r_str = rules.group(1).strip().replace('\n', ' ') if rules else ''
print(f\"{t_str}___SEP____{r_str}\")
" <<< "$XML_DRAFT")

TASK_TEXT="${EXTRACTED%%___SEP____*}"
RULES_TEXT="${EXTRACTED##*___SEP____}"

# ── Phase 2: Semantic Memory Augmentation ─────────────────────────────────────
MEMORY_CONTEXT=""
echo -e "${CYAN}🧠 [Fase 2] Ricerca nella memoria semantica (wz-ai-mem/Turbovec)...${RESET}" >&2

if command -v wz-ai-mem &>/dev/null && [ -n "$TASK_TEXT" ]; then
  # Extract matches and remove terminal noise
  MEMORY_CONTEXT=$(wz-ai-mem search "$TASK_TEXT" | grep -v "Semantic Search via" | grep -v "Naive Text Search" | grep -v "Total:" || true)
fi

FINAL_XML="$XML_DRAFT"

if [[ -n "$MEMORY_CONTEXT" && "$MEMORY_CONTEXT" != *"No matching memories found."* && "$MEMORY_CONTEXT" != *"Il database è vuoto"* ]]; then
  echo -e "${CYAN}✨ [Fase 3] Integrazione dei ricordi e rielaborazione XML...${RESET}" >&2
  
  PHASE3_PROMPT="Sei un Prompt Engineer Senior.
Hai appena redatto questa bozza di prompt XML:

$XML_DRAFT

Ora abbiamo recuperato queste INFORMAZIONI DAL PASSATO (memoria semantica) dell'utente per task simili:
<semantic_memory>
$MEMORY_CONTEXT
</semantic_memory>

ISTRUZIONI:
Migliora e aggiorna la bozza XML fondendo i dettagli utili della memoria semantica all'interno del nodo <rules> o <context>. 
Restituisci SOLO l'XML finale migliorato, mantenendo intatti tutti gli altri nodi strutturali."

  if REFINED_XML=$(execute_llm "$MODEL" "$PHASE3_PROMPT"); then
    FINAL_XML="$REFINED_XML"
  elif REFINED_XML=$(execute_llm "$FALLBACK" "$PHASE3_PROMPT"); then
    FINAL_XML="$REFINED_XML"
  else
    echo -e "${YELLOW}⚠️  Fase 3 fallita, utilizzo la bozza della Fase 1.${RESET}" >&2
  fi
else
  echo -e "${DIM}   Nessuna memoria rilevante passata trovata. Salto la Fase 3.${RESET}" >&2
fi

# Print Final Output
echo "$FINAL_XML"

# ── Phase 4: Persistence (Background) ─────────────────────────────────────────
if command -v wz-ai-mem &>/dev/null && [ -n "$TASK_TEXT" ]; then
  MEM_PAYLOAD="Task Recente: $TASK_TEXT"
  if [ -n "$RULES_TEXT" ]; then
    MEM_PAYLOAD="$MEM_PAYLOAD | Nuove regole/preferenze: $RULES_TEXT"
  fi
  # Run silently in background so we don't block the user
  ( wz-ai-mem store "$MEM_PAYLOAD" &>/dev/null ) &
fi

echo -e "${GREEN}✅ Prompt successfully structured & memorized.${RESET}" >&2
