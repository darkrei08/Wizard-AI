#!/usr/bin/env bash
# ai-release — Semantic versioning and GitHub release automation
# Source: Wizard-AI skill (auto-release)
# Usage: ai-release [patch|minor|major|vX.Y.Z] [--dry-run] [--draft]
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
RESET='\033[0m'

DRY_RUN=false
DRAFT=false
GENERATE_NOTES=false
BUMP=""

usage() {
  echo -e "${BOLD}Usage:${RESET} ai-release [patch|minor|major|vX.Y.Z] [OPTIONS]"
  echo ""
  echo -e "${BOLD}Options:${RESET}"
  echo "  --dry-run        Preview actions without making changes"
  echo "  --draft          Create a draft release (not published)"
  echo "  --generate-notes Let GitHub auto-generate release notes"
  echo "  --help           Show this help"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  ai-release patch                  # v1.2.0 → v1.2.1"
  echo "  ai-release minor                  # v1.2.1 → v1.3.0"
  echo "  ai-release major                  # v1.x.x → v2.0.0"
  echo "  ai-release v2.0.0                 # release specific version"
  echo "  ai-release minor --dry-run        # preview only"
  echo "  ai-release minor --draft          # draft release"
  exit 0
}

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --draft) DRAFT=true ;;
    --generate-notes) GENERATE_NOTES=true ;;
    --help|-h) usage ;;
    *) BUMP="$arg" ;;
  esac
done

if [ -z "$BUMP" ]; then
  echo -e "${RED}Error:${RESET} Specify bump type: patch, minor, major, or vX.Y.Z"
  usage
fi

# ── Check prerequisites ────────────────────────────────────────────────────────
echo -e "${CYAN}🔍 Checking prerequisites...${RESET}"

# Ensure ai-os is available for cross-platform tool management
AI_OS_CMD=""
if command -v ai-os &>/dev/null; then
  AI_OS_CMD="ai-os"
elif [ -x "$HOME/.local/bin/ai-os" ]; then
  AI_OS_CMD="$HOME/.local/bin/ai-os"
elif [ -x "$HOME/.wizard-ai/bin/ai-os" ]; then
  AI_OS_CMD="$HOME/.wizard-ai/bin/ai-os"
fi

if ! command -v git &>/dev/null; then
  echo -e "${RED}❌ git not found${RESET}"; exit 1
fi

# Check working tree
if ! git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
  echo -e "${RED}❌ Not inside a git repository${RESET}"; exit 1
fi

DIRTY=$(git status --short)
if [ -n "$DIRTY" ]; then
  echo -e "${YELLOW}⚠️  Working tree is dirty:${RESET}"
  echo "$DIRTY"
  echo -e "${YELLOW}Commit or stash changes before releasing.${RESET}"
  exit 1
fi

# ── Get latest semver tag ──────────────────────────────────────────────────────
LATEST=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)

if [ -z "$LATEST" ]; then
  echo -e "${YELLOW}⚠️  No semver tags found. Starting from v0.0.0${RESET}"
  LATEST="v0.0.0"
fi

echo -e "  Latest tag: ${BOLD}$LATEST${RESET}"

# Strip 'v'
VERSION="${LATEST#v}"
MAJOR=$(echo "$VERSION" | cut -d. -f1)
MINOR=$(echo "$VERSION" | cut -d. -f2)
PATCH=$(echo "$VERSION" | cut -d. -f3)

# ── Compute new version ────────────────────────────────────────────────────────
case "$BUMP" in
  patch)
    NEW_TAG="v$MAJOR.$MINOR.$((PATCH + 1))"
    ;;
  minor)
    NEW_TAG="v$MAJOR.$((MINOR + 1)).0"
    ;;
  major)
    NEW_TAG="v$((MAJOR + 1)).0.0"
    ;;
  v*)
    NEW_TAG="$BUMP"
    ;;
  *)
    echo -e "${RED}❌ Unknown bump type: $BUMP${RESET}"
    usage
    ;;
esac

# ── Generate changelog ─────────────────────────────────────────────────────────
if [ "$LATEST" = "v0.0.0" ]; then
  CHANGELOG=$(git log --pretty=format:"- %s (%h)" --no-merges | head -30)
else
  CHANGELOG=$(git log "${LATEST}..HEAD" --pretty=format:"- %s (%h)" --no-merges)
fi

if [ -z "$CHANGELOG" ]; then
  CHANGELOG="- No new commits since $LATEST"
fi

# ── Preview ────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}🚀 Release Preview${RESET}"
echo -e "  ${LATEST} → ${BOLD}${NEW_TAG}${RESET}"
echo ""
echo -e "${BOLD}Changelog:${RESET}"
echo "$CHANGELOG"
echo ""

if $DRY_RUN; then
  echo -e "${YELLOW}[DRY RUN] No changes made.${RESET}"
  exit 0
fi

# ── Confirm ────────────────────────────────────────────────────────────────────
read -r -p "$(echo -e "${BOLD}Proceed with release ${NEW_TAG}? [y/N]:${RESET} ")" CONFIRM
if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

# ── Tag ────────────────────────────────────────────────────────────────────────
echo -e "${CYAN}📌 Tagging ${NEW_TAG}...${RESET}"
git tag "$NEW_TAG" -m "Release $NEW_TAG"
git push origin "$NEW_TAG"
echo -e "${GREEN}✅ Tag pushed${RESET}"

# ── GitHub Release ─────────────────────────────────────────────────────────────
# Ensure gh CLI is installed using the correct package manager for this OS
if ! command -v gh &>/dev/null; then
  echo -e "${YELLOW}⚠️  gh CLI not found — installing automatically...${RESET}"
  if [ -n "${AI_OS_CMD:-}" ]; then
    "$AI_OS_CMD" install gh
    # After install, remind user to authenticate
    if ! gh auth status &>/dev/null 2>&1; then
      echo -e ""
      echo -e "${YELLOW}⚡ gh installed! You need to authenticate before creating releases:${RESET}"
      echo -e "   Run: ${CYAN}gh auth login${RESET}   then re-run: ${CYAN}ai-release $BUMP${RESET}"
      exit 0
    fi
  else
    echo -e "${YELLOW}⚠️  ai-os not found. Install gh manually for your OS:${RESET}"
    echo -e "   ${CYAN}Arch/CachyOS:${RESET}   sudo pacman -S github-cli"
    echo -e "   ${CYAN}Ubuntu/Debian:${RESET}  sudo apt install gh"
    echo -e "   ${CYAN}Fedora:${RESET}         sudo dnf install gh"
    echo -e "   ${CYAN}macOS:${RESET}          brew install gh"
    echo -e "   ${CYAN}Windows:${RESET}        winget install GitHub.cli"
    echo -e "   Then run: ${CYAN}gh auth login && ai-release $BUMP${RESET}"
    exit 0
  fi
fi

# Check gh authentication
if ! gh auth status &>/dev/null 2>&1; then
  echo -e ""
  echo -e "${YELLOW}⚡ gh is installed but NOT authenticated.${RESET}"
  echo -e "   Run: ${CYAN}gh auth login${RESET}   then re-run: ${CYAN}ai-release $BUMP${RESET}"
  exit 0
fi

GH_ARGS=("release" "create" "$NEW_TAG" "--title" "$NEW_TAG - $(date +%Y-%m-%d)")

if $DRAFT; then
  GH_ARGS+=("--draft")
fi

if $GENERATE_NOTES; then
  GH_ARGS+=("--generate-notes")
else
  GH_ARGS+=("--notes" "$CHANGELOG")
fi

echo -e "${CYAN}📦 Creating GitHub release...${RESET}"
gh "${GH_ARGS[@]}"
echo -e "${GREEN}✅ GitHub release created: ${NEW_TAG}${RESET}"

echo ""
echo -e "${GREEN}${BOLD}🎉 Release ${NEW_TAG} complete!${RESET}"
