{
  "name": "@darkrei08/wizard-ai-cli",
  "version": "0.52.4",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "Installer for the Wizard-AI environment: AI CLI tools and Claude Code skills (graphify, llmlingua, flashrank, markitdown and more). Clones the repo and runs the platform setup script.",
  "bin": {
    "wizard-ai-cli": "cli.js",
    "wizard-ai": "cli.js",
    "wizard-installer": "scripts/wizard-installer.js",
    "wizard-skills": "scripts/wizard-installer.js",
    "skills-wizard": "scripts/wizard-installer.js",
    "wizard-test": "scripts/wizard-test.js",
    "ai-test": "scripts/wizard-test.js",
    "wz-ai-context": "scripts/wz-ai-context.js",
    "wz-ai-repodocs": "scripts/wz-ai-repodocs.js",
    "wz-ai-pi-configurator": "scripts/wz-ai-pi-configurator.js",
    "wz-ai-benchmark-sync": "scripts/wz-ai-benchmark-sync.js"
  },
  "files": [
    "cli.js",
    "index.js",
    "scripts/"
  ],
  "scripts": {
    "test": "vitest run test/",
    "test:watch": "vitest",
    "test:cli": "node scripts/wizard-test.js run",
    "webnative-inspect": "node scripts/wizard-test.js webnative-inspect",
    "release": "npm version patch && git push --follow-tags && gh release create $(git describe --tags --abbrev=0) --generate-notes && npm publish"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkrei08/Wizard-AI.git"
  },
  "homepage": "https://github.com/darkrei08/Wizard-AI#readme",
  "bugs": {
    "url": "https://github.com/darkrei08/Wizard-AI/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "claude",
    "claude-code",
    "skills",
    "knowledge-graph",
    "llm",
    "token-optimization"
  ],
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@toon-format/toon": "^2.3.1",
    "@vercel/detect-agent": "^1.2.3",
    "pi-extensible-workflows": "^1.0.1",
    "picocolors": "^1.1.1",
    "simple-git": "^3.36.0",
    "xdg-basedir": "^5.1.0"
  }
}
